# Telegram Bot
BOT_TOKEN=                # from @BotFather
WEBAPP_URL=               # your Mini App URL

# Admin auth (NEXT.JS)
ADMIN_PASSWORD=           # password for /admin login
ADMIN_TOKEN=              # random 32+ char secret string for admin session cookie

# Database
DATABASE_URL=             # postgresql://user:pass@host:port/dbname

# SMM panel (twiboost.com)
SMM_API_KEY=

# SMS numbers (smsfast.vip)
SMS_API_KEY=

# MTProto Python service
MTPROTO_API_URL=http://localhost:8080
MTPROTO_API_KEY=          # shared secret for X-MTPROTO-KEY header
TG_API_ID=                # from https://my.telegram.org
TG_API_HASH=              # from https://my.telegram.org

# Bot admin (Telegram user ID)
ADMIN_TG_ID=
